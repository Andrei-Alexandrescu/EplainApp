# Extension (Vite) — copy to .env and rebuild: npm run build
# Full URL to your deployed API (include path)
VITE_EXPLAIN_API_URL=https://your-project.vercel.app/api/explain
# Optional: must match EXPLAIN_GATE_SECRET on the server if you set one
# VITE_EXPLAIN_GATE_SECRET=your-random-secret

# Vercel / server only (set in Vercel Dashboard → Settings → Environment Variables)
# DEEPSEEK_API_KEY=sk-...
# EXPLAIN_GATE_SECRET=optional-shared-secret
